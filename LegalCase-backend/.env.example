PORT=3000
NODE_ENV=development
# MongoDB Atlas (SRV) o local. Incluir el nombre de la base de datos antes del query string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lexvante?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:4200
# Carpeta donde se guardan los archivos subidos (relativa a la raíz del backend).
UPLOADS_DIR=uploads
</content>
