{
  "name": "legalcase-backend",
  "version": "1.0.0",
  "description": "LegalCase Backend — API Express + JavaScript/Node.js (MEAN, arquitectura hexagonal)",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:dev": "node --watch src/index.js",
    "start:prod": "node src/index.js",
    "build": "node scripts/check-syntax.js",
    "seed": "node src/database/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "node scripts/check-syntax.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.0",
    "nodemailer": "^8.0.11",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.js$",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
